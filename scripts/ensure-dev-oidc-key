#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
KEY_FILE="$ROOT_DIR/django/dev_oidc_private_key.pem"

if [[ -f "$KEY_FILE" ]]; then
  exit 0
fi

mkdir -p "$(dirname "$KEY_FILE")"
openssl genpkey -algorithm RSA -out "$KEY_FILE" -pkeyopt rsa_keygen_bits:2048 >/dev/null 2>&1
chmod 600 "$KEY_FILE"
echo "Generated development OIDC private key at $KEY_FILE"
